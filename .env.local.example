# ============================================================
# Forest Retreat — environment variables
# Copy this file to .env.local and fill in real values.
# Add the same vars in Vercel → Project Settings → Environment Variables.
# ============================================================

# --- Supabase (required for booking) ---
# Get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Resend (optional — email confirmations) ---
# https://resend.com/api-keys
# Without this, booking emails are logged to the server console only.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Verified sender. Use onboarding@resend.dev for testing.
RESEND_FROM=Forest Retreat <onboarding@resend.dev>

# --- Host email (where booking notifications go) ---
HOST_EMAIL=hello@forestretreat.lv
