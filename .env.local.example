# ============================================================
# Forest Retreat — environment variables
# Copy this file to .env.local and fill in real values.
# Add the same vars in Vercel → Project Settings → Environment Variables.
# ============================================================

# --- Supabase (required for booking) ---
# Get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Resend (optional — email confirmations) ---
# https://resend.com/api-keys
# Without this, booking emails are logged to the server console only.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Verified sender. Use onboarding@resend.dev for testing.
RESEND_FROM=Forest Retreat <onboarding@resend.dev>

# --- Host contacts (shown to guests in their cabinet) ---
HOST_EMAIL=hello@forestretreat.lv
HOST_PHONE=+371 00 000 000
# WhatsApp link target — digits only (no spaces, with country code, no +)
HOST_WHATSAPP=37100000000

# --- Admin panel (required to access /admin) ---
# What you type at /admin/login
ADMIN_PASSWORD=set-a-strong-password
# Long random string used as the session cookie value (rotate to log everyone out)
# Generate one: openssl rand -hex 32   (or any random 32+ char hex string)
ADMIN_SESSION_SECRET=put-a-32+-char-random-hex-here

# --- Analytics & Ads (optional, but required for measurable Google Ads) ---
# GA4 Measurement ID. Find at https://analytics.google.com → Admin → Data Streams → Web → your stream.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Google Ads Conversion ID + label for the "Booking paid" conversion action.
# Both are shown after creating the action: https://ads.google.com → Goals → New conversion → Website (manual install).
# Leave both blank to skip the Ads pixel — GA4 → Ads conversion import still works.
NEXT_PUBLIC_GADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GADS_PURCHASE_LABEL=

# --- EveryPay (card payments) ---
# Demo creds from https://portal-demo.every-pay.com/merchant_settings/api
# Production from https://portal.every-pay.eu/merchant_settings/general
EVERYPAY_API_USERNAME=d0b5f1471b6f4044
EVERYPAY_API_SECRET=d2e325c073bdb2b24979487ce32ff4b0
# Demo or production
EVERYPAY_MODE=demo
# Processing account name from the merchant portal — defines currency + 3DS
# Common values: EUR3D1 (3DS, EUR), EUR1 (no-3DS dev). Ask EveryPay support if unsure.
EVERYPAY_ACCOUNT_NAME=EUR3D1
